<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

  <include layout="@layout/base_title" />

  <ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_horizontal"
      android:orientation="vertical"
      android:padding="12dp">

      <!-- 光盘行动组 -->
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="光盘行动"
        android:textSize="14sp"
        android:textColor="@color/secondary_text"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="start" />

      <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
          android:id="@+id/btn_save_dish_image"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/save_dish_image"
          android:textColor="@color/button_text"
          android:elevation="2dp" />

        <Button
          android:id="@+id/btn_clear_dish_image"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/clear_dish_image"
          android:textColor="@color/button_text"
          android:elevation="2dp" />
      </LinearLayout>

      <!-- 浇水功能组 -->
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="浇水功能"
        android:textSize="14sp"
        android:textColor="@color/secondary_text"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="start" />

      <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
          android:id="@+id/btn_get_watered_items"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/get_watered_items"
          android:textColor="@color/button_text"
          android:elevation="2dp" />

        <Button
          android:id="@+id/btn_get_watering_items"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/get_watering_items"
          android:textColor="@color/button_text"
          android:elevation="2dp" />
      </LinearLayout>

      <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
          android:id="@+id/btn_fill_watered_friend_list"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/fill_watered_friend_list"
          android:textColor="@color/button_text"
          android:elevation="2dp" />

        <View
          android:layout_width="0dp"
          android:layout_height="0dp"
          android:layout_weight="1" />
      </LinearLayout>

      <!-- 树苗查询组 -->
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="树苗查询"
        android:textSize="14sp"
        android:textColor="@color/secondary_text"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="start" />

      <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
          android:id="@+id/btn_get_tree_items"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/get_tree_items"
          android:textColor="@color/button_text"
          android:elevation="2dp" />

        <Button
          android:id="@+id/btn_get_newTree_items"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/get_newTree_items"
          android:textColor="@color/button_text"
          android:elevation="2dp" />
      </LinearLayout>

      <!-- 解锁查询组 -->
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="解锁查询"
        android:textSize="14sp"
        android:textColor="@color/secondary_text"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="start" />

      <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
          android:id="@+id/btn_query_area_trees"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/query_area_trees"
          android:textColor="@color/button_text"
          android:elevation="2dp" />

        <Button
          android:id="@+id/btn_get_unlock_treeItems"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/get_unlock_treeItems"
          android:textColor="@color/button_text"
          android:elevation="2dp" />
      </LinearLayout>

      <!-- 路线设置组 -->
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="路线设置"
        android:textSize="14sp"
        android:textColor="@color/secondary_text"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="start" />

      <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
          android:id="@+id/btn_set_custom_walk_path_id_list"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/set_custom_walk_path_id_list"
          android:textColor="@color/button_text"
          android:elevation="2dp" />

        <Button
          android:id="@+id/btn_set_custom_walk_path_id_queue"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/set_custom_walk_path_id_queue"
          android:textColor="@color/button_text"
          android:elevation="2dp" />
      </LinearLayout>

      <!-- 版本伪装组 -->
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="版本伪装过滑块"
        android:textSize="14sp"
        android:textColor="@color/secondary_text"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="start" />

      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:layout_marginBottom="4dp">

        <EditText
          android:id="@+id/et_fake_version_name"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:layout_marginEnd="4dp"
          android:hint="版本名(如10.6.58.8000)"
          android:inputType="text"
          android:textSize="13sp"
          android:padding="8dp"
          android:background="@drawable/button_extend"
          android:textColor="@color/button_text" />

        <EditText
          android:id="@+id/et_fake_version_code"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:layout_marginStart="4dp"
          android:hint="版本号(如1881)"
          android:inputType="number"
          android:textSize="13sp"
          android:padding="8dp"
          android:background="@drawable/button_extend"
          android:textColor="@color/button_text" />
      </LinearLayout>

      <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
          android:id="@+id/btn_fake_version_slider"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/fake_version_slider_off"
          android:textColor="@color/button_text"
          android:elevation="2dp" />
      </LinearLayout>

      <!-- 开发者工具组 -->
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="开发者工具"
        android:textSize="14sp"
        android:textColor="@color/secondary_text"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="start" />

      <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
          android:id="@+id/btn_developer_mode"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/developer_mode"
          android:textColor="@color/button_text"
          android:elevation="2dp" />

        <Button
          android:id="@+id/btn_view_rpc_debug_logs"
          style="?android:attr/buttonBarButtonStyle"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_margin="6dp"
          android:layout_weight="1"
          android:background="@drawable/button_extend"
          android:text="@string/view_rpc_debug_logs"
          android:textColor="@color/button_text"
          android:elevation="2dp" />
      </LinearLayout>
    </LinearLayout>
  </ScrollView>
</LinearLayout>
